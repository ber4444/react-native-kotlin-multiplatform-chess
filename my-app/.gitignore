example

# ── chess port ────────────────────────────────────────────────────────────────
# Generated from chess-core (Gradle js(IR) build output) — regenerate with npm run build:core.
src/generated/chess-core/

# Generated from the single-source-of-truth renderer / piece drawables.
src/components/chess/piece-paths.generated.ts
src/components/chess/three-renderer/chess3d-renderer.generated.js

# Generated split glbs (from assets/3d/chess.glb via scripts/split-chess-glb.js).
assets/3d/split/

# Web export
dist-web/

# ── Native projects ──────────────────────────────────────────────────────────
# ios/ and android/ SOURCE is committed (no config plugin re-injects the
# hand-written Stockfish native module + vendored libstockfish.so), but the heavy
# regenerable build output is not.
#
# CocoaPods — regenerate with `pod install`:
ios/Pods/
ios/build/
ios/DerivedData/
**/xcuserdata/
*.xcuserstate
# Gradle / NDK build output — regenerate with `expo run:android` / `./gradlew`:
android/build/
android/.gradle/
android/app/build/
android/app/.cxx/
android/.cxx/
android/local.properties
